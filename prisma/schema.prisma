// MedScribe 数据库 schema
// 文档：https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── 用户 ───────────────────────────────────────────────
// 邮箱 + 密码认证的核心表。密码永远只存 bcrypt 哈希值，绝不存明文。
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String? // 邮箱密码登录用；OAuth 用户没有密码，故可空
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  records  Record[]
}

// ── 病历记录 ─────────────────────────────────────────────
// 一条 SOAP 病历：原始输入 + AI 整理后的四段。挂在某个用户名下。
model Record {
  id         String   @id @default(cuid())
  userId     String
  rawText    String // 医生输入的原始问诊记录
  subjective String // S 主观：患者主诉
  objective  String // O 客观：体征、检查结果
  assessment String // A 评估：诊断/判断
  plan       String // P 计划：治疗方案
  icd        Json? // AI 推荐的 ICD 编码列表 [{code,title,reason}]；按需生成，故可空
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId]) // 按用户查记录很频繁，加索引
}

// ── 以下是 Auth.js (NextAuth) 标准模型 ──────────────────
// 现在用邮箱密码 + JWT，暂时用不到 Session 表，但保留全套
// 以便将来加 OAuth（Google/GitHub 登录）时零改动。

// 第三方登录账号（一个 User 可绑定多个，如同时绑 Google 和 GitHub）
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// 数据库会话（database session 策略时用；我们用 JWT，故暂不写入）
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── ICD-10 权威码表（参考表 / lookup table）─────────────
// 用来给 AI"接地"：模型只能从这张表里选编码，从源头杜绝幻觉。
// 演示用常见病子集，靠 seed 脚本灌入；生产可换成官方全量码表，代码不变。
model IcdCode {
  code  String @id // ICD-10 编码，本身就是主键
  title String // 官方疾病名称
}

// 邮箱验证 / 找回密码用的一次性 token
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
